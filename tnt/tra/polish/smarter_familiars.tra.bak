// loot: full
@15 = ~Twój plecak jest pełny.~

// Initial menu
@100 = ~Tak, czegoś ci trzeba?~
@101 = ~Zmieńmy szyk.~
@102 = ~Musimy porozmawiać o walce.~
@103 = ~Chcę dać ci nowe wskazówki co do łupów.~
@104 = ~Proszę, weź tę miksturę.~
@105 = ~Już nic, może później.~

// Distance
@201 = ~Cały czas a mną podążaj.~
@202 = ~Przestań tak za mną łazić bez przerwy.~
@203 = ~Ruszaj się szybciej, no! Nie zostawaj w tyle.~
@204 = ~Nie biegaj tak szybko. Nie nadążam za tobą.~
@205 = ~Właściwie... nieważne. Odstęp na razie może być.~

// Combat
// Hide in backpack
@301 = ~Wskocz do mojego plecaka jak tylko zobaczysz niebezpieczeństwo.~
@302 = ~Nie chowaj się do mojego plecaka gdy zobaczysz wrogów.~
@303 = ~Natychmiast wskakuj do mojego plecaka, gdy odniesiesz obrażenia.~
@304 = ~Natychmiast wskakuj do mojego plecaka, jeśli odniesiesz poważne obrażenia.~
@306 = ~Wychodź z plecaka, gdy wrogowie znikną.~
@307 = ~Gdy już schowasz się w plecaku, nie ruszaj się stamtąd. Ostrożności nigdy za wiele.~
// Notification after fight
@309 = ~Nie zawracaj mi głowy jęczeniem, nie obchodzi mnie, że jesteś ranny.~
@310 = ~Daj mi znać po walce, jeśli odniesiesz jakieś obrażenia. ~
@311 = ~Daj mi znać po walce, jeśli odniesiesz poważne obrażenia.~
// Tactics
@312 = ~Gdy ktoś cię zaatakuje, wycofaj się na chwilę, a potem ruszaj z powrotem na wroga.~
@313 = ~Nie wycofuj się z walki, nawet jeśli ktoś cię atakuje.~
@314 = ~W czasie walki nie atakuj wrogów, dopóki ci nie każę.~
@315 = ~W czasie walki atakuj wrogów, gdy tylko ich zobaczysz.~
@316 = ~W czasie walki atakuj wrogów, gdy tylko ich zobaczysz, zaczynając od przeciwników czarujących.~

// Loot
@400 = ~Przestań podnosić przedmioty, dobrze?~
@401 = ~Przynoś mi wszystko. Każdą cenną rzecz.~
@402 = ~Podnoś każde złoto, jakie znajdziesz.~
@403 = ~Nie podnoś złota, które znajdziesz.~
@404 = ~Podnoś wszystkie klejnoty, jakie znajdziesz.~
@405 = ~Podnoś tylko wartościową i magiczną biżuterię.~
@406 = ~Podnoś tylko magiczną biżuterię.~
@407 = ~Nie podnoś biżuterii.~
@408 = ~Podnoś całą magiczną amunicję, jaką znajdziesz.~
@409 = ~Nie podnoś amunicji.~
@410 = ~Jeśli znajdziesz jakieś mikstury, natychmiast mi je przynieś!~
@411 = ~Przestań zbierać mikstury.~
@412 = ~Przynoś mi wszystkie zwoje, jakie znajdziesz.~
@413 = ~Nie potrzebuję już więcej zwojów.~
@414 = ~Zabieraj skalpy bandytów, których zabijemy. Jest za nie niezła nagroda.~
@415 = ~Skończ już z tym zbieraniem skalpów, dobrze? To obrzydliwe.~
@416 = ~Skorupy ankhegów, skóry zimowych wilków, głowy wiwern – potrzebuję wszystkiego.~
@417 = ~Nie chcę więcej skór ani skorup, mamy zapas.~
@418 = ~Nie, niczego.~
@419 = ~Jak sobie życzysz.~

// Gear - not implemented
@500 = ~Porozmawiajmy o twoim ekwipunku.~
@501 = ~Weź tę powracającą strzałkę. Lepiej, żebyś atakował z dystansu.~
@502 = ~Będzie jak chcesz.~
@503 = ~Zrobione.~
@504 = ~Nie, właściwie twój ekwipunek jest w porządku.~

