#: easy_traps.tra:1
msgid "Uh, I smell a trap."
msgstr "Um, wyczuwam pułapkę."

#: easy_traps.tra:2
msgid "Careful. Something's not quite right here."
msgstr "Ostrożnie. Coś tu nie gra."

#: easy_traps.tra:3
msgid "Stop! It's a trap!"
msgstr "Stop! To pułapka!"

#: easy_traps.tra:4
msgid "I sense a trap!"
msgstr "Wyczuwam pułapkę!"

#: easy_traps.tra:5
msgid "Hmm... We should tread lightly here."
msgstr "Hmm... Powinniśmy stąpać ostrożnie."

#: easy_traps.tra:6
msgid "Wait, wait. Let's take a closer look at this."
msgstr "Zaraz, zaraz. Przyjrzyjmy się temu bliżej."

#: easy_traps.tra:7
msgid "I sense danger."
msgstr "Wyczuwam zagrożenie."

#: easy_traps.tra:8
msgid "Watch your step. Looks suspicious."
msgstr "Uważajcie. To wygląda podejrzanie."

#: easy_traps.tra:9
msgid "Hold on. See this?"
msgstr "Zaczekajcie. Widzicie to?"

