msgid "Invisibility Purge"
msgstr "Ujawnienie niewidzialnych"

#: working_non_detection.tra:2
msgid "Invisibility Purge and True Sight"
msgstr "Ujawnienie niewidzialnych i Prawdziwe widzenie"

#: working_non_detection.tra:3
